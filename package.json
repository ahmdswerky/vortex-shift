{
  "name": "vortex-shift",
  "version": "0.1.0",
  "description": "CLI for full server migration between Rocky Linux servers.",
  "private": true,
  "type": "module",
  "bin": {
    "vortex-shift": "./dist/bundle.cjs"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "bundle": "esbuild src/index.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist/bundle.cjs --external:cpu-features --external:sshcrypto --external:*.node",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "package": "npm run bundle && PKG_CACHE_PATH=/tmp/.pkg-cache pkg ."
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "cli-progress": "^3.12.0",
    "commander": "^13.1.0",
    "date-fns": "^4.1.0",
    "execa": "^9.6.0",
    "fs-extra": "^11.3.0",
    "inquirer": "^12.6.0",
    "node-ssh": "^13.2.1",
    "ora": "^8.2.0",
    "p-limit": "^6.2.0",
    "p-retry": "^6.2.1",
    "winston": "^3.17.0",
    "zod": "^3.25.7"
  },
  "devDependencies": {
    "@types/node": "^22.15.18",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "@yao-pkg/pkg": "^6.19.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.26.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  },
  "pkg": {
    "targets": [
      "node20-linux-x64",
      "node20-linux-arm64"
    ],
    "outputPath": "bin"
  }
}
